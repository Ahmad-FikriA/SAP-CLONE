{
  "name": "kti-sap-mock",
  "version": "1.0.0",
  "description": "KTI SmartCare — SAP Mock API Server with Admin UI",
  "main": "src/server.js",
  "scripts": {
    "prestart": "node src/migrate_users.js && node src/migrate_corrective_spk.js && node src/migrate_k3_safety.js && node src/migrate_inspection_enums.js",
    "predev": "node src/migrate_users.js && node src/migrate_corrective_spk.js && node src/migrate_k3_safety.js && node src/migrate_inspection_enums.js",
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/seed.js",
    "seed:preventive": "node src/preventive_seed.js",
    "backup:coords": "node src/backup_coords.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.18.2",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.7",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "verbose": true,
    "forceExit": true,
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/seed.js",
      "!src/preventive_seed.js",
      "!src/server.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
